{
  "name": "hapbeat-devtools-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "fetch-docs": "node scripts/fetch-docs.mjs",
    "fetch-docs:watch": "node scripts/fetch-docs.mjs --watch",
    "dev": "concurrently --kill-others --names \"fetch,astro\" --prefix-colors \"blue,green\" \"npm:fetch-docs:watch\" \"astro dev\"",
    "build": "npm run fetch-docs && astro build && node scripts/postbuild-fix-link-targets.mjs",
    "preview": "astro preview",
    "reorder": "node scripts/reorder.mjs",
    "i18n:sync": "node scripts/i18n-sync.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.0",
    "astro": "^6.0.0",
    "playwright": "^1.59.1",
    "rehype-mermaid": "^3.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "image-size": "^2.0.2",
    "starlight-llms-txt": "^0.10.0"
  }
}
