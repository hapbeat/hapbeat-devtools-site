---
/**
 * ToolCard
 *
 * トップページの「ツール」グリッド用カード。
 * .design-handoff/docs.css の .tool / .tool__head / .tool__icon / .tool__name /
 * .tool__chip / .tool__desc / .tool__meta を踏襲。
 *
 * Props:
 *   - title: ツール名 (例: "Hapbeat Studio")
 *   - description: 1〜2 行説明
 *   - href: リンク先
 *   - icon: 任意 (emoji / 文字 / SVG inline。簡易には emoji 1 文字)
 *   - chip: 右上ピル (例: "Web App", "Desktop", "Unity SDK")
 *   - chipVariant: "default" | "wip"
 *   - meta: 下部のモノスペースメタ列 (string[])
 */
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  chip?: string;
  chipVariant?: 'default' | 'wip';
  meta?: string[];
}

const {
  title,
  description,
  href,
  icon = '',
  chip,
  chipVariant = 'default',
  meta = [],
} = Astro.props;

// 同一ドメインなら同タブ、別ドメインなら新タブ。例外: /studio/ は別 SPA で新タブ。
const SITE_HOSTNAME = 'devtools.hapbeat.com';
const isStudioPath = (p) => p === '/studio' || p.startsWith('/studio/');
const isNewTab = (() => {
  if (!href || typeof href !== 'string') return false;
  if (href.startsWith('#')) return false;
  if (href.startsWith('mailto:') || href.startsWith('tel:')) return true;
  if (href.startsWith('/')) return isStudioPath(href);
  try {
    const u = new URL(href);
    if (u.hostname !== SITE_HOSTNAME) return true;
    return isStudioPath(u.pathname);
  } catch { return false; }
})();
const linkProps = isNewTab
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<a class="hb-tool" href={href} {...linkProps}>
  <div class="hb-tool__head">
    {icon && <div class="hb-tool__icon" aria-hidden="true">{icon}</div>}
    <h3 class="hb-tool__name">{title}</h3>
    {chip && (
      <span
        class:list={[
          'hb-tool__chip',
          chipVariant === 'wip' && 'hb-tool__chip--wip',
        ]}
      >
        {chip}
      </span>
    )}
  </div>
  <p class="hb-tool__desc">{description}</p>
  {meta.length > 0 && (
    <div class="hb-tool__meta">
      {meta.map((m) => <span>{m}</span>)}
    </div>
  )}
</a>

<style>
  .hb-tool {
    padding: 20px 20px 18px;
    /* SupportedSdks カードと統一: ほぼ直角 (2px) + 左ソリッド縦線 (ブランド purple) */
    border: 1px solid var(--hb-line);
    border-left: 4px solid var(--hb-purple);
    border-radius: 2px;
    background: var(--hb-bg-elev);
    box-shadow: var(--hb-shadow-sm);
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }
  .hb-tool:hover {
    border-top-color: var(--hb-line-strong);
    border-right-color: var(--hb-line-strong);
    border-bottom-color: var(--hb-line-strong);
    box-shadow: var(--hb-shadow-md);
    text-decoration: none;
  }
  .hb-tool__head {
    display: flex;
    align-items: center;
    gap: 12px;
    justify-content: space-between;
  }
  .hb-tool__icon {
    width: 38px;
    height: 38px;
    border-radius: 9px;
    display: grid;
    place-items: center;
    background: var(--hb-purple-soft);
    color: var(--hb-purple-ink);
    font-size: 18px;
    flex: none;
  }
  :global([data-theme='dark']) .hb-tool__icon {
    color: var(--sl-color-accent-high);
  }
  .hb-tool__name {
    font-size: 16px;
    font-weight: 600;
    color: var(--hb-ink);
    margin: 0;
    flex: 1;
    line-height: 1.3;
  }
  .hb-tool__chip {
    font-family: var(--hb-font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    color: var(--hb-ink-mute);
    background: var(--hb-bg-soft);
    border: 1px solid var(--hb-line);
    padding: 2px 8px;
    border-radius: 999px;
    flex: none;
  }
  .hb-tool__chip--wip {
    color: oklch(0.4 0.13 50);
    background: oklch(0.96 0.04 75);
    border-color: oklch(0.78 0.06 75);
  }
  :global([data-theme='dark']) .hb-tool__chip--wip {
    color: oklch(0.86 0.1 75);
    background: oklch(0.32 0.08 75);
    border-color: oklch(0.5 0.1 75);
  }
  .hb-tool__desc {
    margin: 0;
    font-size: 13.5px;
    color: var(--hb-ink-soft);
    line-height: 1.6;
  }
  .hb-tool__meta {
    margin-top: auto;
    padding-top: 8px;
    font-family: var(--hb-font-mono);
    font-size: 11.5px;
    color: var(--hb-ink-mute);
    display: flex;
    gap: 14px;
    border-top: 1px solid var(--hb-line);
    flex-wrap: wrap;
  }
  .hb-tool__meta span {
    display: inline-flex;
    gap: 5px;
    align-items: center;
  }
</style>
