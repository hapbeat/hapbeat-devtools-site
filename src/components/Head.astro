---
/**
 * Head override.
 *
 * Starlight default の Head (meta / preload / favicon 等) を温存しつつ、
 * Astro View Transitions を全ページで有効化する。
 *
 * 機能:
 *   (1) View Transitions (ClientRouter) — ページ遷移の白フラッシュ抑止
 *   (2) サイドバー scroll 位置の保持 (astro:before-swap / after-swap)
 *   (3) サイドバー / TOC の collapse トグル + localStorage 永続化
 *       早期 inline script で <html> に class を当てて FOUC 抑止
 *
 * リサイズ機能は撤去済み (固定幅 + collapse 方針)。
 */
import Default from '@astrojs/starlight/components/Head.astro';
import { ClientRouter } from 'astro:transitions';
---

<Default {...Astro.props}><slot /></Default>
<ClientRouter />

<script is:inline>
  (() => {
    const KEY_SCROLL = 'hb-sidebar-scroll';
    const KEY_SIDEBAR_COLLAPSED = 'hb-sidebar-collapsed';
    const KEY_TOC_COLLAPSED = 'hb-toc-collapsed';

    // ---------- 早期適用 (FOUC 抑止) ----------
    // DOM 構築前 (head 内 inline script) に <html> へクラスを当てる。
    // これでサイドバーが一瞬広がってから閉じる、という FOUC を防ぐ。
    try {
      if (localStorage.getItem(KEY_SIDEBAR_COLLAPSED) === '1') {
        document.documentElement.classList.add('hb-sidebar-collapsed');
      }
      if (localStorage.getItem(KEY_TOC_COLLAPSED) === '1') {
        document.documentElement.classList.add('hb-toc-collapsed');
      }
    } catch {}

    // ---------- Sidebar scroll restore (View Transitions 対応) ----------
    const getSidebar = () =>
      document.getElementById('starlight__sidebar');

    document.addEventListener('astro:before-swap', () => {
      const sb = getSidebar();
      if (sb) {
        try {
          sessionStorage.setItem(KEY_SCROLL, String(sb.scrollTop));
        } catch {}
      }
    });

    // ---------- Collapse トグルのバインド ----------
    function bindToggle() {
      // 各ボタン kind ごとに { class, key } を渡して共通処理
      const setupBtn = (kind, cls, key) => {
        const collapsed = document.documentElement.classList.contains(cls);
        document
          .querySelectorAll('[data-hb-toggle="' + kind + '"]')
          .forEach((btn) => {
            // 初期 aria-expanded (a11y: SR ユーザに展開/格納状態を伝える)
            btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
            if (btn.dataset.hbBound === '1') return;
            btn.dataset.hbBound = '1';
            btn.addEventListener('click', () => {
              const next = document.documentElement.classList.toggle(cls);
              try {
                localStorage.setItem(key, next ? '1' : '0');
              } catch {}
              // 全 toggle ボタンの aria-expanded を再同期
              document
                .querySelectorAll('[data-hb-toggle="' + kind + '"]')
                .forEach((b) =>
                  b.setAttribute('aria-expanded', next ? 'false' : 'true')
                );
            });
          });
      };
      setupBtn('sidebar', 'hb-sidebar-collapsed', KEY_SIDEBAR_COLLAPSED);
      setupBtn('toc', 'hb-toc-collapsed', KEY_TOC_COLLAPSED);
    }

    // ---------- Group label クリック → 先頭ページへ navigate ----------
    // Starlight default では <summary> 全体が details の開閉ハンドラだが、
    // ユーザ要望: 見出しクリックで「そのグループの先頭ページ」に遷移、
    // caret クリックでのみ開閉、にしたい。
    // .group-label にイベントを当てて preventDefault で開閉を止め、
    // ul の最初の <a> に navigate する。
    function bindGroupLabelNav() {
      document
        .querySelectorAll(
          '.sidebar-content ul.top-level > li > details > summary > .group-label'
        )
        .forEach((label) => {
          if (label.dataset.hbBound === '1') return;
          label.dataset.hbBound = '1';
          label.addEventListener('click', (e) => {
            const details = label.closest('details');
            if (!details) return;
            const firstLink = details.querySelector('ul a[href]');
            if (!firstLink) return;
            e.preventDefault();
            e.stopPropagation();
            const href = firstLink.getAttribute('href');
            if (href) window.location.href = href;
          });
        });
    }

    function setup() {
      // Scroll restore (after-swap で発火)
      const sb = getSidebar();
      if (sb) {
        try {
          const v = sessionStorage.getItem(KEY_SCROLL);
          if (v != null) sb.scrollTop = parseInt(v, 10) || 0;
        } catch {}
      }
      bindToggle();
      bindGroupLabelNav();
    }

    document.addEventListener('DOMContentLoaded', setup);
    document.addEventListener('astro:after-swap', setup);
  })();
</script>
