---
/**
 * TableOfContents override.
 *
 * 右サイドバー TOC の「目次」見出しと同じ行の右端に KindBadge を配置する。
 *
 * 設計判断:
 *   - h1 隣接や上部に置くと長いタイトルでレイアウトが揺れるため、幅固定の
 *     右サイドバーに置く方が確実
 *   - 「目次」h2 と同一行右端にしたいが h2 は Default 内部にあるため、
 *     position: absolute で wrap → starlight-toc を覆う形にする。
 *   - 右サイドバーの sl-container を relative にする CSS は global で当てる。
 */
import Default from '@astrojs/starlight/components/TableOfContents.astro';
import KindBadge from './KindBadge.astro';

const entry = (Astro.locals as any)?.starlightRoute?.entry;
const kind: string | undefined = entry?.data?.kind;
---
{kind && (
  <div class="toc-kind-anchor">
    <KindBadge kind={kind} />
  </div>
)}
<Default {...Astro.props} />

<style>
  /* 右サイドバー panel の sl-container を相対配置にして、その中で
     toc-kind-anchor を絶対配置する。これで「目次」h2 と同じ行の右端に
     badge が並ぶ (h2 は通常通り上部に配置されるため top: 0 で揃う)。 */
  :global(.right-sidebar-panel .sl-container) {
    position: relative;
  }
  .toc-kind-anchor {
    position: absolute;
    top: 0;
    right: 0;
    z-index: 1;
    pointer-events: none; /* バッジ自体のみクリック可、空白部分は素通り */
  }
  .toc-kind-anchor :global(.kind-badge) {
    margin-bottom: 0;
    pointer-events: auto;
    /* h2 のフォントサイズに合わせて若干小さく */
    font-size: 0.7rem;
    padding: 0.15em 0.55em;
  }
</style>
