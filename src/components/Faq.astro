---
/**
 * Faq — 単一質問+回答のシンプルなブロック。
 * 開閉式アコーディオンは廃止 (FAQ 量が少ないので開く操作が冗長)。
 *
 * 利用例 (mdx):
 *   <Faq question="デバイスが見つからない">
 *     - ファームウェア書き込み済みか確認
 *     - 同一ネットワークか確認
 *   </Faq>
 */
interface Props {
  question: string;
}
const { question } = Astro.props;
---

<div class="hb-faq">
  <div class="hb-faq__q">{question}</div>
  <div class="hb-faq__a">
    <slot />
  </div>
</div>

<style>
  .hb-faq {
    border: 1px solid var(--hb-line);
    border-radius: var(--hb-radius);
    background: var(--hb-bg-elev);
    margin-bottom: 12px;
    padding: 14px 18px 16px;
  }
  .hb-faq__q {
    font-weight: 600;
    color: var(--hb-ink);
    font-size: 15px;
    margin-bottom: 8px;
  }
  .hb-faq__a {
    font-size: 14px;
    color: var(--hb-ink-soft);
    line-height: 1.7;
  }
  .hb-faq__a > :global(p:first-child) {
    margin-top: 0;
  }
  .hb-faq__a > :global(p:last-child),
  .hb-faq__a > :global(ul:last-child) {
    margin-bottom: 0;
  }
  .hb-faq__a :global(ul) {
    margin: 0;
    padding-left: 1.2em;
  }
</style>
