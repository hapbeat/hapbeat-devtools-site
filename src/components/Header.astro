---
/**
 * Header override.
 *
 * design の .topbar レイアウトを再現:
 *   [ brand | search | nav (Downloads / FAQ) | lang-switch | theme | github ]
 *
 * Collapse 用のトグルボタンはこの topbar には置かず、別途 floating な
 * 位置 (.hb-side-toggle--left/--right) で各サイドバーの境界線に乗せる。
 * components.css 側で実装。
 */
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import Search from 'virtual:starlight/components/Search';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';

// メニュートグル (mobile) は Starlight 標準を使う
import MenuButton from '@astrojs/starlight/components/MobileMenuToggle.astro';
---

<div class="hb-topbar">
  <div class="hb-topbar__left">
    <SiteTitle {...Astro.props} />
  </div>

  <div class="hb-topbar__center">
    <Search {...Astro.props} />
  </div>

  <div class="hb-topbar__right">
    <nav class="hb-topbar__nav" aria-label="主要セクション">
      <a href="/downloads/">Downloads</a>
      <a href="/faq/">FAQ</a>
    </nav>
    <LanguageSelect {...Astro.props} />
    <div class="hb-topbar__icons">
      <ThemeSelect {...Astro.props} />
      <SocialIcons {...Astro.props} />
    </div>
  </div>

  <div class="hb-topbar__menu">
    <MenuButton />
  </div>
</div>

{/* Floating sidebar / TOC collapse トグル (各サイドバーの境界に固定配置)。
    components.css 側で .hb-side-toggle のスタイルを定義 */}
<button
  type="button"
  class="hb-side-toggle hb-side-toggle--left"
  data-hb-toggle="sidebar"
  aria-label="サイドバーの表示/非表示"
  title="サイドバーの表示/非表示"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="15 18 9 12 15 6" />
  </svg>
</button>
<button
  type="button"
  class="hb-side-toggle hb-side-toggle--right"
  data-hb-toggle="toc"
  aria-label="目次の表示/非表示"
  title="目次の表示/非表示"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="9 18 15 12 9 6" />
  </svg>
</button>

<style>
  .hb-topbar {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    grid-template-areas: 'left center right menu';
    align-items: center;
    gap: 32px;
    width: 100%;
    padding: 0 8px;
  }
  .hb-topbar__left {
    grid-area: left;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hb-topbar__center {
    grid-area: center;
    display: flex;
    justify-content: center;
    min-width: 0;
  }
  .hb-topbar__right {
    grid-area: right;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hb-topbar__menu {
    grid-area: menu;
    display: none;
  }
  .hb-topbar__nav {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .hb-topbar__nav a {
    height: 32px;
    padding: 0 12px;
    border-radius: 7px;
    font-size: 13px;
    color: var(--hb-ink-mute);
    display: inline-flex;
    align-items: center;
    text-decoration: none !important;
    transition: background 0.15s, color 0.15s;
  }
  .hb-topbar__nav a:hover {
    color: var(--hb-ink);
    background: var(--hb-bg-soft);
  }
  .hb-topbar__nav a[aria-current='page'] {
    color: var(--hb-ink);
    background: var(--hb-bg-soft);
  }
  .hb-topbar__icons {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding-left: 8px;
    border-left: 1px solid var(--hb-line);
    margin-left: 4px;
  }

  /* タブレット以下: nav の text label は隠して icons + lang のみ */
  @media (max-width: 60rem) {
    .hb-topbar {
      grid-template-columns: auto 1fr auto auto;
      gap: 20px;
    }
    .hb-topbar__nav {
      display: none;
    }
  }

  /* モバイル: search を非表示にして brand + lang + menu のみ */
  @media (max-width: 50rem) {
    .hb-topbar {
      grid-template-columns: auto 1fr auto;
      grid-template-areas: 'left right menu';
      gap: 12px;
    }
    .hb-topbar__center {
      display: none;
    }
    .hb-topbar__menu {
      display: flex;
    }
    .hb-topbar__icons {
      border-left: 0;
      padding-left: 0;
      margin-left: 0;
    }
  }
</style>
