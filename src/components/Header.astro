---
/**
 * Header override.
 *
 * design の .topbar レイアウトを再現:
 *   [ brand | search | nav (Downloads / FAQ) | lang-switch | theme | github ]
 *
 * サイドバー / TOC は viewport 幅で自動レスポンシブ (components.css 参照)。
 * 開閉トグルは持たない。
 */
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import Search from 'virtual:starlight/components/Search';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';

// メニュートグル (mobile) は Starlight 標準を PageFrame.astro が描画する。
// ここでは描画せず、CSS で position を上書きしてヘッダー左に再配置する
// (Starlight default は position:fixed で右端に固定)。
---

<div class="hb-topbar">
  <div class="hb-topbar__left">
    <SiteTitle {...Astro.props} />
  </div>

  <div class="hb-topbar__center">
    <Search {...Astro.props} />
  </div>

  <div class="hb-topbar__right">
    <nav class="hb-topbar__nav" aria-label="主要セクション">
      <a href="/docs/getting-started/" class="hb-topbar__nav--lvl1">Docs</a>
      <a href="/downloads/" class="hb-topbar__nav--lvl2">Downloads</a>
      <a href="/docs/support/" class="hb-topbar__nav--lvl3">Support</a>
      <a href="/studio/" class="hb-topbar__cta" target="_blank" rel="noopener noreferrer">
        Studio
        <svg class="hb-topbar__cta-icon" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="9" x2="13" y2="1"/>
          <polyline points="8.5,1 13,1 13,5.5"/>
          <path d="M7,1.5 H2.5 C1.67,1.5 1,2.17 1,3 V11.5 C1,12.33 1.67,13 2.5,13 H11.5 C12.33,13 13,12.33 13,11.5 V8"/>
        </svg>
      </a>
    </nav>
    <div class="hb-topbar__icons">
      <LanguageSelect {...Astro.props} />
      <ThemeSelect {...Astro.props} />
      <SocialIcons {...Astro.props} />
    </div>
  </div>
</div>

<style>
  .hb-topbar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-areas: 'left center right';
    align-items: center;
    gap: 32px;
    width: 100%;
    padding: 0 8px;
  }
  .hb-topbar__left {
    grid-area: left;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hb-topbar__center {
    grid-area: center;
    display: flex;
    justify-content: center;
    min-width: 0;
  }
  .hb-topbar__right {
    grid-area: right;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hb-topbar__menu {
    grid-area: menu;
    display: none;
  }
  .hb-topbar__nav {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .hb-topbar__nav a {
    height: 40px;
    padding: 0 13px;
    border-radius: 8px;
    font-size: 13px;
    color: var(--hb-ink-mute);
    background: transparent;
    display: inline-flex;
    align-items: center;
    text-decoration: none !important;
    transition: background 0.15s, color 0.15s;
  }
  .hb-topbar__nav a:hover {
    color: var(--hb-ink);
    background: var(--hb-bg-soft);
  }
  .hb-topbar__nav a[aria-current='page'] {
    color: var(--hb-ink);
    background: var(--hb-bg-soft);
  }
  /* Studio CTA: 彩度低めの purple tint 背景。border なし。常時表示。 */
  .hb-topbar__nav a.hb-topbar__cta {
    color: var(--hb-purple-ink);
    background: transparent;
    border: none;
    font-weight: 500;
    padding: 0 13px;
    margin-left: 2px;
    gap: 5px;
  }
  .hb-topbar__nav a.hb-topbar__cta:hover {
    color: var(--hb-purple-ink);
    background: var(--hb-purple-soft);
  }
  .hb-topbar__cta-icon {
    width: 12px;
    height: 12px;
    flex: none;
    transform: translateY(-0.5px);
  }
  .hb-topbar__icons {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding-left: 8px;
    border-left: 1px solid var(--hb-line);
    margin-left: 4px;
  }

  /* 段階的 hide。優先度順 (高 → 低):
     右「| 以降の icons」グループ (lang/theme/github) は nav よりも低優先度。
     icons が先に消え、次に nav の lvl3 → lvl2 の順で消える。
     Docs (lvl1) は常時表示。

     最小幅試算 (icons 全消し時):
       brand "Hapbeat" 96 + hamburger 92 + nav 232(Docs+DL+Support) + 余白 ≈ 446px
     → 28rem (448px) を boundary に Support 維持

     ※ 基底 `.hb-topbar__nav a` (0,1,1) より specificity を上げるため
     `a.hb-topbar__nav--lvlX` 形式で書く。 */
  /* 右 icons (低優先度から先に消える) */
  @media (max-width: calc(50rem - 0.01px)) {
    .hb-topbar__icons :global(.social-icons) {
      display: none;
    }
  }
  @media (max-width: calc(40rem - 0.01px)) {
    .hb-topbar__icons :global(starlight-theme-toggle) {
      display: none;
    }
  }
  @media (max-width: calc(36rem - 0.01px)) {
    .hb-topbar__icons :global(.hb-lang) {
      display: none;
    }
  }
  /* nav (中・高優先度)。実測: 500px で全部 fit、450px だと overflow するため
     30rem (480px) を Support の boundary、26rem (416px) を Downloads の boundary に。 */
  @media (max-width: calc(30rem - 0.01px)) {
    .hb-topbar__nav a.hb-topbar__nav--lvl3 {
      display: none;
    }
  }
  @media (max-width: calc(26rem - 0.01px)) {
    .hb-topbar__nav a.hb-topbar__nav--lvl2 {
      display: none;
    }
  }

  /* タブレット帯 (60rem 未満): gap を詰める */
  @media (max-width: 60rem) {
    .hb-topbar {
      gap: 16px;
    }
  }

  /* モバイル: search 隠して brand + right。
     PageFrame.astro が描画する MobileMenuToggle は CSS で
     ヘッダー左に再配置する (components.css 側)。
     ハンバーガー領域確保 (padding-left) は docs ページ
     (sidebar あり) のみに適用する。 */
  @media (max-width: 50rem) {
    .hb-topbar {
      grid-template-columns: auto 1fr auto;
      grid-template-areas: 'left center right';
      gap: 10px;
    }
    :global(html[data-has-sidebar]) .hb-topbar {
      padding-left: 56px;
    }
    .hb-topbar__center {
      display: none;
    }
    .hb-topbar__icons {
      border-left: 0;
      padding-left: 0;
      margin-left: 0;
    }
  }
</style>
