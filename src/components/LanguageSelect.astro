---
/**
 * LanguageSelect override.
 *
 * 1 言語切替トグル: 現在 JA なら EN へ、現在 EN なら JA へ navigate。
 * アイコン (globe + 略号) のコンパクト表示でヘッダーの幅を最小化する。
 *
 * design の segmented JA/EN ピルから「現在表示中言語のアイコン + 切替ボタン」
 * 一体型に変更 (言語数 2 のため select / dropdown より単純なトグルが最適)。
 */

const path = Astro.url.pathname;
const isEn = path.startsWith('/en/') || path === '/en';

// 切替先 URL
const targetUrl = isEn
  ? path.replace(/^\/en/, '') || '/'
  : '/en' + (path === '/' ? '/' : path);

// 表示ラベル: 現在の言語を示す。クリックで他言語へ。
const currentLabel = isEn ? 'EN' : 'JA';
const otherLabel = isEn ? 'JA' : 'EN';
const otherLang = isEn ? 'ja' : 'en';
---

<a
  class="hb-lang"
  href={targetUrl}
  hreflang={otherLang}
  aria-label={`Switch language to ${otherLabel === 'EN' ? 'English' : 'Japanese'}`}
  title={`${currentLabel} → ${otherLabel}`}
>
  <svg
    class="hb-lang__icon"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="9"></circle>
    <path d="M3 12h18"></path>
    <path d="M12 3a14 14 0 0 1 0 18"></path>
    <path d="M12 3a14 14 0 0 0 0 18"></path>
  </svg>
  <span class="hb-lang__label">{currentLabel}</span>
</a>

<style>
  .hb-lang {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    height: 32px;
    padding: 0 9px;
    border-radius: 7px;
    color: var(--hb-ink-mute);
    text-decoration: none !important;
    font-family: var(--hb-font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    transition: background 0.15s, color 0.15s;
    flex: none;
  }
  .hb-lang:hover {
    background: var(--hb-bg-soft);
    color: var(--hb-ink);
  }
  .hb-lang__icon {
    flex: none;
  }
  .hb-lang__label {
    line-height: 1;
  }
</style>
