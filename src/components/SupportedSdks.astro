---
/**
 * SupportedSdks
 *
 * トップページの「対応 SDK」セクション。訪問者が「何と組み合わせて Hapbeat を
 * 使えるか」を一目で把握できるよう、横長カードを 2 列 (モバイル 1 列) で並べる。
 *
 * ロゴの扱い（利用許諾の確認結果, 2026-06-22。詳細は public/sdk-logos/SOURCES.md）:
 *   - Python : PSF 商標ポリシーで未改変ロゴの互換性表示が可（™ 併記 + 帰属）。公式ロゴを使用。
 *   - JavaScript : "JS" バッジは MIT。公式ロゴを使用。
 *   - Unity : ブランドガイドラインが第三者の自社製品宣伝でのロゴ使用を認めないため、
 *             ロゴではなく名称（文字ワードマーク）で表示する。書面許可があれば差し替え可。
 *
 * 新しい SDK は SDKS 配列に 1 つ足す。ロゴが使える場合は mark にファイル名
 * (public/sdk-logos/<file>) を、使えない/無い場合は mark:'word' を指定する。
 *
 * Props:
 *   - lang: 'ja' | 'en'   href prefix と表示文言の出し分け
 */
interface Sdk {
  id: string;
  name: string;
  mark: string; // 'word' か public/sdk-logos/ 配下のファイル名
  chip: string; // 配布形態
  slug: string; // /docs/sdk-integration/<slug>/getting-started/
  accent: string; // 左アクセント色（CSS color）
  tm?: boolean; // 名称に ™ を付ける（Python 商標表示）
  desc: { ja: string; en: string };
}

const SDKS: Sdk[] = [
  {
    id: 'unity',
    name: 'Unity',
    mark: 'word',
    chip: 'UPM',
    slug: 'unity-sdk',
    accent: 'var(--hb-ink-mute)',
    desc: {
      ja: 'Unity 製ゲーム・VR/MR アプリ向け。Trigger と EventMap で既存プロジェクトに触覚を追加できます。',
      en: 'For Unity games and VR/MR apps. Add haptics to an existing project with Trigger components and EventMap.',
    },
  },
  {
    id: 'python',
    name: 'Python',
    mark: 'python.svg',
    chip: 'PyPI',
    slug: 'python-sdk',
    accent: '#3776ab',
    tm: true,
    desc: {
      ja: '研究・プロトタイピング・メディアアート向け。OSC ブリッジ同梱で外部ツールとも連携できます。',
      en: 'For research, prototyping, and media art. A bundled OSC bridge connects external tools.',
    },
  },
  {
    id: 'javascript',
    name: 'JavaScript',
    mark: 'javascript.svg',
    chip: 'npm',
    slug: 'js-sdk',
    accent: '#eab308',
    desc: {
      ja: 'Web・Node・Electron 向け。ブラウザは Helper 経由、Node は UDP 直送で再生します。',
      en: 'For Web, Node, and Electron. Browser via Helper; Node sends over UDP directly.',
    },
  },
];

interface Props {
  lang?: 'ja' | 'en';
}
const { lang = 'ja' } = Astro.props;
const prefix = lang === 'en' ? '/en' : '';
const more =
  lang === 'en'
    ? 'More SDKs (Unreal, Godot, TouchDesigner, VRChat) are on the way.'
    : 'Unreal / Godot / TouchDesigner / VRChat などにも順次対応予定です。';
const trademark =
  lang === 'en'
    ? 'Names and logos are trademarks of their respective owners (Python: Python Software Foundation; JavaScript logo: Chris Williams, MIT; Unity: Unity Technologies).'
    : '各名称・ロゴは各社の商標です（Python: Python Software Foundation／JavaScript ロゴ: Chris Williams, MIT／Unity: Unity Technologies）。';
---

<div class="hb-sdks">
  {
    SDKS.map((s) => (
      <a
        class="hb-sdks__card"
        href={`${prefix}/docs/sdk-integration/${s.slug}/getting-started/`}
        style={`--accent:${s.accent}`}
        data-mark={s.mark === 'word' ? 'word' : 'img'}
      >
        <span class="hb-sdks__mark">
          {s.mark === 'word' ? (
            <span class="hb-sdks__wordmark">{s.name}</span>
          ) : (
            <img src={`/sdk-logos/${s.mark}`} alt={`${s.name} logo`} width="40" height="40" />
          )}
        </span>
        <span class="hb-sdks__body">
          <span class="hb-sdks__titlerow">
            {s.mark !== 'word' && (
              <span class="hb-sdks__name">
                {s.name}
                {s.tm && <sup class="hb-sdks__tm">™</sup>}
              </span>
            )}
            <span class="hb-sdks__chip">{s.chip}</span>
          </span>
          <span class="hb-sdks__desc">{lang === 'en' ? s.desc.en : s.desc.ja}</span>
        </span>
        <span class="hb-sdks__arrow" aria-hidden="true">→</span>
      </a>
    ))
  }
</div>
<p class="hb-sdks__more">{more}</p>
<p class="hb-sdks__tm-note">{trademark}</p>

<style>
  .hb-sdks {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin: 0 0 12px;
  }
  @media (max-width: 48rem) {
    .hb-sdks {
      grid-template-columns: 1fr;
    }
  }
  .hb-sdks__card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    /* 直角 + 左端のソリッドな縦線 (アクセント色) */
    border: 1px solid var(--hb-line);
    border-left: 4px solid var(--accent);
    border-radius: 0;
    background: var(--hb-bg-elev);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
  }
  .hb-sdks__card:hover {
    /* 左の縦線は accent のまま、他 3 辺だけ強調 */
    border-top-color: var(--hb-line-strong);
    border-right-color: var(--hb-line-strong);
    border-bottom-color: var(--hb-line-strong);
    box-shadow: var(--hb-shadow-md);
    text-decoration: none;
  }
  .hb-sdks__mark {
    flex: none;
    display: grid;
    place-items: center;
    height: 46px;
  }
  .hb-sdks__card[data-mark='img'] .hb-sdks__mark {
    width: 46px;
  }
  .hb-sdks__mark img {
    width: 40px;
    height: 40px;
    display: block;
  }
  .hb-sdks__wordmark {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--hb-ink);
    white-space: nowrap;
    padding: 0 4px;
  }
  .hb-sdks__body {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
    flex: 1;
  }
  .hb-sdks__titlerow {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }
  .hb-sdks__name {
    font-size: 15px;
    font-weight: 600;
    color: var(--hb-ink);
    line-height: 1.2;
  }
  .hb-sdks__tm {
    font-size: 9px;
    font-weight: 500;
    color: var(--hb-ink-mute);
    vertical-align: super;
    margin-left: 1px;
  }
  .hb-sdks__chip {
    font-family: var(--hb-font-mono);
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--hb-ink);
    background: var(--hb-bg-soft);
    border: 1px solid var(--hb-line-strong);
    padding: 2px 8px;
    border-radius: 3px;
  }
  .hb-sdks__desc {
    font-size: 12.5px;
    color: var(--hb-ink-soft);
    line-height: 1.5;
  }
  .hb-sdks__arrow {
    flex: none;
    align-self: center;
    font-size: 16px;
    color: var(--hb-ink-faint);
    transition:
      transform 0.15s,
      color 0.15s;
  }
  .hb-sdks__card:hover .hb-sdks__arrow {
    transform: translateX(3px);
    color: var(--hb-purple);
  }
  .hb-sdks__more {
    margin: 0 0 6px;
    font-size: 12.5px;
    color: var(--hb-ink-mute);
    line-height: 1.6;
  }
  .hb-sdks__tm-note {
    margin: 0 0 4px;
    font-size: 11px;
    color: var(--hb-ink-faint);
    line-height: 1.55;
  }
  @media (prefers-reduced-motion: reduce) {
    .hb-sdks__card,
    .hb-sdks__arrow {
      transition: none;
    }
    .hb-sdks__card:hover {
      transform: none;
    }
  }
</style>
