---
/**
 * SiteTitle override.
 *
 * Starlight default の SiteTitle を、Hapbeat ブランドマーク
 * (グラデ四角 + ターミナルプロンプト `>_`) + "Hapbeat / devtools" ロックアップに差替。
 * グリフは devtools であることを示す意図。背景の水平グラデ (favicon と共通) でブランドを担保する。
 *
 * 表示優先度:
 *   - ロゴマーク + "Hapbeat" は常時表示
 *   - "devtools" サブタイトルは ≥80rem のみ (ヘッダーが詰まる時は省略)
 *   - version chip は廃止 (UI 上の優先度が低い)
 *
 * design 出典: public/favicon.svg と同一グリフ
 */

// 現在のロケールを URL から判定し、ロゴのリンク先を維持する。
// EN ページなら /en/ ホーム、JA(root) なら / ホームへ。
// (これをしないと EN ページでロゴを押すと JA トップに飛んでしまう)
const isEn = Astro.url.pathname === '/en' || Astro.url.pathname.startsWith('/en/');
const homeUrl = isEn ? '/en/' : (import.meta.env.BASE_URL || '/');
---

<a class="hb-brand" href={homeUrl} aria-label="Hapbeat devtools — ホーム">
  <span class="hb-brand__mark" aria-hidden="true">
    <svg viewBox="0 0 32 32" width="26" height="26">
      <g fill="none" stroke="rgba(255,255,255,0.96)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10 11 L15 16 L10 21"></path>
        <path d="M17 21 L23 21"></path>
      </g>
    </svg>
  </span>
  <span class="hb-brand__name">
    <span class="hb-brand__primary">Hapbeat</span>
    <span class="hb-brand__sub">devtools</span>
  </span>
</a>

<style>
  .hb-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--sl-color-text);
    text-decoration: none;
    font-family: var(--hb-font-sans);
    line-height: 1;
  }
  .hb-brand:hover {
    text-decoration: none;
  }
  .hb-brand__mark {
    width: 26px;
    height: 26px;
    border-radius: 7px;
    background: var(--hb-gradient);
    box-shadow: var(--hb-shadow-sm);
    display: inline-grid;
    place-items: center;
    position: relative;
    flex: none;
  }
  .hb-brand__mark svg {
    width: 26px;
    height: 26px;
    display: block;
  }
  .hb-brand__name {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }
  .hb-brand__primary {
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.01em;
    color: var(--sl-color-text);
  }
  .hb-brand__sub {
    font-weight: 400;
    font-size: 13px;
    color: var(--sl-color-gray-2);
    letter-spacing: 0;
  }

  /* < 60rem (タブレット未満): "devtools" サブタイトルを省略 */
  @media (max-width: calc(60rem - 0.01px)) {
    .hb-brand__sub {
      display: none;
    }
  }
</style>
