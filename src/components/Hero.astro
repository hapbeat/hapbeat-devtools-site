---
/**
 * Hero override.
 *
 * Starlight default の Hero (template: splash 用) を design ハンドオフの
 * .hero レイアウトに置き換える。
 *
 * 構造 (2-column on desktop, stacks on mobile):
 *   左カラム:
 *     eyebrow chip ("DEVELOPER PORTAL · v0.4 PREVIEW")
 *     + h1 (<em>Hapbeat</em> はグラデーション color)
 *     + lede 段落
 *     + 2 ボタン (primary=dark / ghost=outline)
 *   右カラム:
 *     Unity SDK 最小コード例 (docs サイトらしい硬派な装飾)
 *
 * frontmatter `hero` から title / tagline / actions を受け取る。
 * title / tagline は HTML を許容 (`set:html`)。
 */
// Starlight 0.30+ では entry は Astro.locals.starlightRoute.entry に格納される
// (旧 API は Astro.props.entry だった)。404 等で entry が無いケースを optional
// chain で吸収。
const entry = (Astro.locals as any)?.starlightRoute?.entry;
const hero = entry?.data?.hero ?? {};
const title: string | undefined = hero.title;
const tagline: string | undefined = hero.tagline;
type Action = { text?: string; link?: string; variant?: string };
const actions: Action[] = Array.isArray(hero.actions) ? hero.actions : [];

// hero data が無いページ (404 / 通常ページ) では何も描画しない
const shouldRender = !!(title || tagline || actions.length);

const eyebrowText = 'DEVELOPER PORTAL · v0.4 PREVIEW';
---

{shouldRender && (
<section class="hb-hero">
  <div class="hb-hero__copy">
    <span class="hb-hero__eyebrow">
      <span class="hb-hero__dot" aria-hidden="true"></span>
      {eyebrowText}
    </span>

    {title && <h1 class="hb-hero__title" id="_top" data-page-title set:html={title} />}

    {tagline && <p class="hb-hero__lede" set:html={tagline} />}

    {actions.length > 0 && (
      <div class="hb-hero__cta">
        {actions.map((a) => {
          const isPrimary = a.variant === 'primary';
          // 同一ドメインなら同タブ、別ドメインなら新タブ。
          // 例外: /studio/ は別 SPA なので新タブ。
          const href = a.link || '';
          const SITE_HOSTNAME = 'devtools.hapbeat.com';
          const isStudioPath = (p: string) => p === '/studio' || p.startsWith('/studio/');
          const isNewTab = (() => {
            if (!href) return false;
            if (href.startsWith('#')) return false;
            if (href.startsWith('mailto:') || href.startsWith('tel:')) return true;
            if (href.startsWith('/')) return isStudioPath(href);
            try {
              const u = new URL(href);
              if (u.hostname !== SITE_HOSTNAME) return true;
              return isStudioPath(u.pathname);
            } catch { return false; }
          })();
          const linkProps = isNewTab
            ? { target: '_blank', rel: 'noopener noreferrer' }
            : {};
          return (
            <a
              href={a.link}
              {...linkProps}
              class:list={[
                'hb-btn',
                isPrimary ? 'hb-btn--primary' : 'hb-btn--ghost',
              ]}
            >
              {!isPrimary && (
                <svg
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" />
                </svg>
              )}
              <span>{a.text}</span>
              {isPrimary && (
                <svg
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              )}
            </a>
          );
        })}
      </div>
    )}
  </div>

  {/* 右カラム: Unity SDK の代表的な使い方を Inspector 風モックで表現。
      EventMap (ScriptableObject) + Trigger Component の組み合わせを 2 パネル
      で示す。コードは書かず Inspector で設定する declarative ワークフロー。 */}
  <div class="hb-hero__inspector" aria-hidden="true">
    <div class="hb-insp__panel">
      <div class="hb-insp__head">
        <span class="hb-insp__head-icon">📋</span>
        <span>Combat.eventmap (ScriptableObject)</span>
      </div>
      <div class="hb-insp__row hb-insp__row--folder">
        <span class="hb-insp__caret">▾</span>
        <span class="hb-insp__folder-label">Entries</span>
      </div>
      <div class="hb-insp__row hb-insp__row--child">
        <span class="hb-insp__label">id</span>
        <span class="hb-insp__val"><span class="hb-insp__pill">hit</span></span>
      </div>
      <div class="hb-insp__row hb-insp__row--child">
        <span class="hb-insp__label">id</span>
        <span class="hb-insp__val"><span class="hb-insp__pill">powerup</span></span>
      </div>
    </div>

    <div class="hb-insp__arrow" aria-hidden="true">↓ assign</div>

    <div class="hb-insp__panel">
      <div class="hb-insp__head">
        <span class="hb-insp__head-icon">⚙</span>
        <span>Player ▸ Inspector</span>
      </div>
      <div class="hb-insp__row hb-insp__row--folder">
        <span class="hb-insp__caret">▾</span>
        <span class="hb-insp__folder-label">Hapbeat Collision Trigger</span>
      </div>
      <div class="hb-insp__row">
        <span class="hb-insp__label">Event Map</span>
        <span class="hb-insp__val"><span class="hb-insp__ref">▸ Combat.eventmap</span></span>
      </div>
      <div class="hb-insp__row">
        <span class="hb-insp__label">Entry</span>
        <span class="hb-insp__val"><span class="hb-insp__pill">hit</span> <span class="hb-insp__caret">▾</span></span>
      </div>
      <div class="hb-insp__row">
        <span class="hb-insp__label">Trigger</span>
        <span class="hb-insp__val">OnCollisionEnter <span class="hb-insp__caret">▾</span></span>
      </div>
      <div class="hb-insp__row">
        <span class="hb-insp__label">Gain Mode</span>
        <span class="hb-insp__val">VelocityScaled <span class="hb-insp__caret">▾</span></span>
      </div>
    </div>
  </div>
</section>
)}
