---
/**
 * Campaign.astro — Hapbeat 無償貸出プログラム バナー (v7: slim)
 *
 * v7 方針:
 *   - トップページの情報量を抑えるため `.campaign-slim` レイアウトに切替
 *   - Perk 3段 / fine 3ブロック構成は撤去し、1 行に圧縮した補足表示のみ
 *   - 長期利用 (数ヶ月) はサブコピー内に集約
 *
 * v5/v6 から引き継ぐ方針:
 *   - 常設プログラムとして運用 ("キャンペーン" 表記廃止)
 *   - プレゼント・進呈の事前約束はしない (個別相談で対応)
 *   - "無料" 表記は使わず "無償" に統一
 *   - 長期利用は具体数値を出さず "数ヶ月" 表記
 *
 * Props:
 *   formUrl: 応募 Google Form の URL (必須)
 */
interface Props {
  formUrl: string;
}
const { formUrl } = Astro.props;
---

<section class="campaign-slim" aria-labelledby="campaign-title">
  <div class="campaign-slim__main">
    <div class="campaign-slim__ribbon">
      <span class="campaign__ribbon-dot"></span>
      OPEN PROGRAM · 開発者・クリエイター向け
    </div>
    <h2 id="campaign-title" class="campaign-slim__title">
      <strong>無線版 Hapbeat</strong> を <em>誰でも無償</em> でお試しいただけます
    </h2>
    <p class="campaign-slim__sub">
      ご自身のコンテンツ・作品・研究などで<strong>触覚要素を追加したい</strong>方にお勧め
      <span class="campaign-slim__sub-note">（ゲーム開発者・VR/XRクリエイター・メディアアーティスト・研究者 など）</span>
    </p>
    <span class="campaign-slim__fine">
      まずは２週間、ご相談で<strong>数ヶ月の長期利用</strong>もOK ·
      <a href="https://hapbeat.com/products/duo-wireless/" target="_blank" rel="noopener">Duo WL</a> 2台 /
      <a href="https://hapbeat.com/products/band-wireless/" target="_blank" rel="noopener">Band WL</a> 1台まで
    </span>
  </div>
  <a class="btn btn--campaign" href={formUrl} target="_blank" rel="noopener">
    Google Form で応募
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
  </a>
</section>
