# build
dist/
.astro/

# deps
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env
.env
.env.local
.env.production

# editor
.vscode/
.idea/
.claude/
.obsidian/
.DS_Store

# crash dumps / local junk
*.stackdump

# fetched docs (regenerated on build by scripts/fetch-docs.mjs)
# docs/ja/ が真の編集場所 (JA root) → src/content/docs/docs/ へ flat copy。
# docs/en/ (EN) → src/content/docs/en/docs/ へ flat copy。contracts は外部 fetch。
src/content/docs/docs/
src/content/docs/en/docs/

# Design handoff (reference material from Claude Design)
# 抽出済みの React/HTML プロトタイプは git 管理外。
# 必要に応じて design-handoff.zip を別途保存してアーカイブする。
.design-handoff/

# Internal dev notes (use workspace dev-notes/<repo-name>/ instead)
dev-notes/
CLAUDE.md
instructions/

# fetched demos (regenerated on build by scripts/fetch-demos.mjs)
# source of truth は hapbeat-js-sdk/examples/games/ 側。
public/demos/
